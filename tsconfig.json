{
  "compilerOptions": {
    "target": "es2022",
    "module": "node16", // ← CHANGE THIS
    "rootDir": "./src",
    "moduleResolution": "node16", // ← Can also simplify this
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": false,
    "types": [
      "node"
    ],
    "isolatedModules": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}